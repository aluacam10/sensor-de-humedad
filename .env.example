# SERIAL CONFIGURATION
SERIAL_PORT=COM3
SERIAL_BAUD=9600
USE_WEB_SERIAL=1

# REDIS/UPSTASH CONFIGURATION (para almacenamiento remoto en Vercel)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# DATA CONFIGURATION
READ_INTERVAL_SEC=0.2
SAVE_INTERVAL_SEC=60
MAX_HISTORY_RECORDS=200

# KEYS CONFIGURATION
KV_LATEST_KEY=sensor:latest
KV_HISTORY_KEY=sensor:history
KV_DEVICES_KEY=sensor:devices
